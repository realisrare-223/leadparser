# ============================================================
# LeadParser Dashboard — Environment Variables
# ============================================================
# Copy to .env.local and fill in your Supabase project values.
# Get these from: supabase.com/dashboard → Project Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose on the client (browser).
# Keep the service role key server-side only (never NEXT_PUBLIC_).
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
