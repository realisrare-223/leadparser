# ============================================================
# LeadParser Dashboard — Environment Variables
# ============================================================
# Copy to .env.local and fill in your Supabase project values.
# Get these from: supabase.com/dashboard → Project Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose on the client (browser).
# Keep the service role key server-side only (never NEXT_PUBLIC_).
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER prefix with NEXT_PUBLIC_
# Required for admin to create/delete caller accounts
# Found at: supabase.com/dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
